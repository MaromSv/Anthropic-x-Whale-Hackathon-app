<?xml version="1.0" encoding="utf-8"?>
<!--
  Allow cleartext HTTP only for the loopback tile server. Everything else
  (POI data, segments, etc.) is read from local files; we don't make any
  outbound network calls. Without this, MapLibre's tile fetches against
  http://127.0.0.1:<port> are blocked starting at API 28.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>

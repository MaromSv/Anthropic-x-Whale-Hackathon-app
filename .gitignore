# Android / Gradle
**/build/
**/.gradle/
android/local.properties
android/app/release/
*.keystore
!android/app/debug.keystore

# Models (too large for git, push via adb)
*.litertlm
*.task
*.bin
# Bundled Tier-0 assets (~520 KB total) live in git so the APK builds
# without running scripts/build-pack/density-grid-build.py.
!app/src/main/assets/bundled/*.bin

# Offline map bundle — generated by scripts/build-pack/*. The brouter.jar
# is pulled by the gradle setupBundledAssets task; the skeleton mbtiles is
# built by scripts/build-pack/skeleton-build.sh. Per-region packs are
# downloaded at runtime by PackDownloader (plan §4), not bundled.
app/libs/brouter.jar
app/src/main/assets/bundled/skeleton.mbtiles
app/src/main/assets/bundled/skeleton.rd5

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store
Thumbs.db

# Node / Expo legacy (keep ignoring)
node_modules/
.expo/
